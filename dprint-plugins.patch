diff --git a/pkgs/by-name/dp/dprint/plugins/update-plugins.py b/pkgs/by-name/dp/dprint/plugins/update-plugins.py
new file mode 100755
index 000000000000..4acc6d919127
--- /dev/null
+++ b/pkgs/by-name/dp/dprint/plugins/update-plugins.py
@@ -0,0 +1,209 @@
+#!/usr/bin/env nix-shell
+#!nix-shell -i python -p nix nixfmt-rfc-style 'python3.withPackages (pp: [ pp.requests ])'
+
+import fcntl
+import json
+import os
+from pathlib import Path
+import sys
+import subprocess
+import requests
+
+pname = ""
+if len(sys.argv) > 1:
+    pname = sys.argv[1]
+else:
+    pname = os.environ.get("UPDATE_NIX_PNAME", "")
+
+SCRIPT_DIR = Path(os.path.dirname(os.path.realpath(__file__)))
+DEFAULT_FILE = SCRIPT_DIR / "default.nix"
+OUT_FILE = SCRIPT_DIR / "plugins.nix"
+
+# different json files per pname, to avoid writing to same file
+TEMP_FILE = SCRIPT_DIR / f"plugins_{pname}.json"
+GEN_FILE = SCRIPT_DIR / "gen.nix"
+
+# lock file ideally should be unlinked but unlinking causes failures with manual batch update
+LOCK_FILE = SCRIPT_DIR / "lockfile.LOCK"
+
+
+# https://stackoverflow.com/a/30941681
+def acquire_lock():
+    """acquire exclusive lock file access"""
+    locked_file_descriptor = open(LOCK_FILE, "w+")
+    fcntl.lockf(locked_file_descriptor, fcntl.LOCK_EX)
+    return locked_file_descriptor
+
+
+def release_lock(locked_file_descriptor):
+    """release exclusive lock file access"""
+    locked_file_descriptor.close()
+
+
+# get sri hash for a url, no unpack
+def nix_prefetch_url(url, name, algo="sha256"):
+    hash = (
+        subprocess.check_output(
+            ["nix-prefetch-url", "--type", algo, "--name", name, url]
+        )
+        .decode("utf-8")
+        .rstrip()
+    )
+    sri = (
+        subprocess.check_output(
+            [
+                "nix",
+                "--extra-experimental-features",
+                "nix-command",
+                "hash",
+                "convert",
+                "--hash-algo",
+                algo,
+                "--to",
+                "sri",
+                hash,
+            ]
+        )
+        .decode("utf-8")
+        .rstrip()
+    )
+    return sri
+
+
+# json to nix, file to file
+def json_to_nix(jsonfile, filename):
+    # lock before writing to the shared nix file
+    global lock_fd
+    lock_fd = acquire_lock()
+
+    with open(filename, "w+", encoding="utf8") as f:
+        f.write("# generated by update script. DO NOT EDIT!\n")
+    subprocess.run(
+        f"nix --extra-experimental-features nix-command eval --expr 'builtins.fromJSON (builtins.readFile {jsonfile})' --impure | nixfmt >> {filename}",
+        shell=True,
+    )
+
+    # remove temp json file, never needed
+    jsonfile.unlink()
+
+
+# nix to json, file to file
+def nix_to_json(filename, jsonfile):
+    subprocess.run(
+        f"nix --extra-experimental-features nix-command eval --json -f {filename} --impure > {jsonfile}",
+        shell=True,
+    )
+
+
+def get_update_url(plugin_url):
+    """Get a single plugin's update url given the plugin's url"""
+
+    # remove -version.wasm at the end
+    url = "-".join(plugin_url.split("-")[:-1])
+    names = url.split("/")[3:]
+    # if single name then -> dprint/<name>
+    if len(names) == 1:
+        names.insert(0, "dprint")
+    return "https://plugins.dprint.dev/" + "/".join(names) + "/latest.json"
+
+
+def update_plugin_by_name(name):
+    """Update a single plugin in plugins.nix"""
+
+    nix_to_json(OUT_FILE, TEMP_FILE)
+    with open(TEMP_FILE, "r", encoding="utf8") as f:
+        plugins = json.load(f)
+    if name not in plugins:
+        print(f"plugin named {name} not found in plugins.nix")
+        exit(1)
+    p = plugins[name]
+    data = requests.get(p["updateUrl"]).json()
+    p["url"] = data["url"]
+    p["version"] = data["version"]
+    p["hash"] = nix_prefetch_url(data["url"], f"{name}-{data["version"]}.wasm")
+
+    with open(TEMP_FILE, "w+", encoding="utf8") as f:
+        json.dump(plugins, f, indent=2)
+
+    json_to_nix(TEMP_FILE, OUT_FILE)
+
+
+def update_plugins():
+    """Update all the plugins in plugins.nix"""
+
+    data = requests.get("https://plugins.dprint.dev/info.json").json()["latest"]
+
+    with open(TEMP_FILE, "w+", encoding="utf8") as f:
+        result = {}
+        for e in data:
+            update_url = get_update_url(e["url"])
+            pname = e["name"]
+            if "/" in e["name"]:
+                pname = pname.replace("/", "-")
+            result[pname] = {
+                "url": e["url"],
+                "hash": nix_prefetch_url(e["url"], f"{pname}-{e["version"]}.wasm"),
+                "updateUrl": update_url,
+                "pname": pname,
+                "version": e["version"],
+                "description": e["description"],
+                "fileExtensions": e["fileExtensions"],
+                "configExcludes": e["configExcludes"],
+                "configKey": e["configKey"],
+            }
+        json.dump(result, f, indent=2)
+
+    json_to_nix(TEMP_FILE, OUT_FILE)
+
+
+# Here meta.description is required due to how updateScript works
+# see https://github.com/NixOS/nixpkgs/blob/c4f2bb3f2e143db7a9b117a4727ea33e97d49f9f/maintainers/scripts/update.nix#L72
+# it removes all identical update scripts and just calls once
+# this allows it to treat each package as having a different updateScript
+# and makes the batch parallel update with maintainers/scripts/update.nix work
+def gen_fetch_drv(pname):
+    return f"""fetchurl {{
+        inherit (plugins.{pname}) hash url;
+        name = "{pname}-${{plugins.{pname}.version}}.wasm";
+        meta.description = plugins.{pname}.description;
+        passthru.updateScript = ./update-plugins.py;
+        passthru.initConfig = plugins.{pname};
+    }}"""
+
+
+# generate the default.nix file
+def generate_default_nix():
+    nix_to_json(OUT_FILE, TEMP_FILE)
+    with open(TEMP_FILE, "r", encoding="utf8") as f:
+        plugins = json.load(f)
+    with open(GEN_FILE, "w+", encoding="utf8") as f:
+        f.write("# generated by update script. DO NOT EDIT!\n")
+        f.write("{ fetchurl }:\n")
+        f.write("let plugins = import ./plugins.nix; in\n")
+        f.write("{\n")
+        for k, v in plugins.items():
+            f.write(f"""{k} = {gen_fetch_drv(k)};\n""")
+        f.write("}\n")
+    subprocess.run(
+        f"cat {GEN_FILE} | nixfmt > {DEFAULT_FILE}",
+        shell=True,
+    )
+    GEN_FILE.unlink()
+    TEMP_FILE.unlink()
+
+
+# locking is required when updating manually like
+# nix-shell maintainers/scripts/update.nix --argstr skip-prompt true --argstr path dprint-plugins
+# r-ryantm nixpkgs-update does it per package, never simultaneously
+lock_fd = None
+
+if pname != "":
+    update_plugin_by_name(pname)
+else:
+    update_plugins()
+
+# generate default.nix
+generate_default_nix()
+
+# relase lock finally
+release_lock(lock_fd)
